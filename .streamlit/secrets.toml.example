# 🔒 Streamlit Secrets — Password Gate + Supabase Connection
# ─────────────────────────────────────────────────
# วิธีใช้ (Local):
#   1. copy ไฟล์นี้เป็น `.streamlit/secrets.toml`
#   2. แก้ค่าทั้งหมดด้านล่าง
#   3. .gitignore จะกัน secrets.toml ไม่ commit ขึ้น git
#
# วิธีใช้ (Streamlit Cloud):
#   1. ไปที่ Streamlit Cloud → App settings → Secrets
#   2. paste คอนเทนต์ด้านล่าง (แก้ password + connection)
#   3. Save → app จะ auto-redeploy
# ─────────────────────────────────────────────────

# ─── 1) Password สำหรับเข้าใช้งาน OR Dashboard ───
app_password = "ตั้งรหัสผ่านของคุณเอง"

# ─── 2) Supabase PostgreSQL Connection ───
# Format: postgresql://postgres.[project-ref]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
# (ใช้ Transaction Pooler port 6543 — เหมาะกับ Streamlit serverless)
database_url = "postgresql://postgres.[project-ref]:YOUR_PASSWORD_HERE@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require"

# ─── 3) Database mode switch ───
# "supabase" = ใช้ PostgreSQL cloud  |  "sqlite" = ใช้ local file (dev)
db_mode = "supabase"

# ─── 4) Schema แยกแอพ (ใช้ project เดียวกับ minor OR ได้โดยไม่ชนกัน) ───
# main OR ใช้ "orsurg" · minor OR ใช้ "minor" (หรือ public)
# ทุก query จะวิ่งเข้า schema นี้อัตโนมัติ (search_path) → ข้อมูล 2 แอพแยกขาดกัน
db_schema = "orsurg"

# 💡 Tips:
# - เปลี่ยน password ทุกครั้งหลัง demo
# - ใช้ password ที่ยาว/ซับซ้อนสำหรับ production
# - ถ้าไม่ใส่ app_password → app จะ bypass login (local dev mode)
# - ถ้า db_mode = "sqlite" → ไม่จำเป็นต้องใส่ database_url
# - หาก Supabase password หลุด → reset ทันทีที่ Project Settings → Database

# ───────────────────────────────────────────────────────────────
# 🔐 PIN ผู้ดูแล — ปลดล็อกอัปโหลด CSV บนบอร์ด + Maintenance + ข้อมูลพยาบาล
#    ไม่ตั้ง = ฟีเจอร์เหล่านั้นถูกล็อก (fail-closed)
admin_pin = "ตั้งรหัสของคุณเอง"

# 💾 snapshot_keep_pii — ❌ ยกเลิกแล้ว (11 มิ.ย. 2026 หลังเหตุ PII ขึ้น cloud)
#    ระบบ mask ชื่อ/HN เสมอทุกที่ (ชื่อต้น+นามสกุลย่อ · HN 4 ตัวท้าย) — ตั้งค่านี้ไปก็ไม่มีผล

# 🔒 database_url ควรลงท้ายด้วย ?sslmode=require เสมอ (บังคับเข้ารหัสการเชื่อมต่อ)
